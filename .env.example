# Copy to .env and fill in. The Flask API also reads these from the process environment.

# Required for /api/chat and spreadsheet LLM ingest (get a key at https://console.groq.com/)
GROQ_API_KEY=
# Optional: override Groq model id
# GROQ_MODEL=llama-3.3-70b-versatile

# Neo4j (local Docker or Neo4j Desktop)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Change this to your local Neo4j Desktop DBMS password (default is often 'password')
NEO4J_PASS=password

# MongoDB (local Docker or Atlas)
MONGO_URI=mongodb://localhost:27017/hpe_san

# Gemini AI (for chatbot service)
GEMINI_API_KEY=

# Optional: OpenAI fallback
OPENAI_API_KEY=

# JWT secret for authentication
JWT_SECRET=super_secret_hpe_jwt_key

# Elasticsearch (Optional - set to true to bypass connection attempts completely)
DISABLE_ES=true
